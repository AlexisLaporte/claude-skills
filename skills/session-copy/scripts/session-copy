#!/usr/bin/env python3
"""Duplicate a Claude Code session JSONL with a new UUID."""

import argparse
import json
import sys
import uuid
from pathlib import Path

CLAUDE_DIR = Path.home() / ".claude"
PROJECTS_DIR = CLAUDE_DIR / "projects"


def find_project_dir() -> Path | None:
    """Find the project dir for the current working directory."""
    cwd = str(Path.cwd())
    # Claude Code encodes paths by replacing / with -
    encoded = cwd.replace("/", "-")
    candidate = PROJECTS_DIR / encoded
    if candidate.exists():
        return candidate
    # Fallback: search for a matching prefix
    for d in sorted(PROJECTS_DIR.iterdir()):
        if d.is_dir() and encoded.startswith(d.name):
            return d
    return None


def find_current_session(project_dir: Path) -> tuple[str, Path] | None:
    """Find the most recently modified JSONL in the project dir."""
    jsonls = sorted(project_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not jsonls:
        return None
    # The current session is likely being written to right now (most recent)
    path = jsonls[0]
    session_id = path.stem
    return session_id, path


def find_session_file(session_id: str) -> Path | None:
    """Find a session JSONL by ID across all project dirs."""
    for project_dir in PROJECTS_DIR.iterdir():
        if not project_dir.is_dir():
            continue
        candidate = project_dir / f"{session_id}.jsonl"
        if candidate.exists():
            return candidate
    return None


def copy_session(source: Path, session_id: str | None = None) -> tuple[str, Path]:
    """Copy a session JSONL with a new UUID, return (new_id, new_path)."""
    new_id = str(uuid.uuid4())
    dest = source.parent / f"{new_id}.jsonl"

    with open(source) as f:
        lines = f.readlines()

    with open(dest, "w") as out:
        for line in lines:
            obj = json.loads(line)
            if "sessionId" in obj:
                obj["sessionId"] = new_id
            out.write(json.dumps(obj) + "\n")

    return new_id, dest


def main():
    parser = argparse.ArgumentParser(description="Duplicate a Claude Code session")
    parser.add_argument("session_id", nargs="?", help="Session ID to copy (default: current/latest)")
    args = parser.parse_args()

    if args.session_id:
        source = find_session_file(args.session_id)
        if not source:
            print(f"Error: session {args.session_id} not found", file=sys.stderr)
            sys.exit(1)
    else:
        project_dir = find_project_dir()
        if not project_dir:
            print("Error: cannot detect project dir. Pass a session ID explicitly.", file=sys.stderr)
            sys.exit(1)
        result = find_current_session(project_dir)
        if not result:
            print(f"Error: no sessions found in {project_dir}", file=sys.stderr)
            sys.exit(1)
        _, source = result

    new_id, new_path = copy_session(source)
    print(f"Session copied: {new_id}")
    print(f"File: {new_path}")
    print(f"\nResume with:\n  claude --resume {new_id}")


if __name__ == "__main__":
    main()
